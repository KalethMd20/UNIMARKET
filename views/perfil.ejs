<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UniMarket — Mi Perfil</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--primary:#6366f1;--primary-hover:#4f46e5;--bg:#0f1117;--surface:#1a1d27;--surface-2:#22263a;--border:#2e3248;--text:#f1f5f9;--muted:#8b95b0}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1.5rem;background-image:radial-gradient(ellipse at 20% 50%,rgba(99,102,241,.08) 0%,transparent 60%)}
    .card{background:var(--surface);border:1px solid var(--border);border-radius:1.5rem;padding:2.5rem 2rem;width:100%;max-width:500px;box-shadow:0 24px 64px rgba(0,0,0,.4)}
    .header{display:flex;align-items:center;gap:1rem;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border)}
    .avatar{width:56px;height:56px;background:var(--primary);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;flex-shrink:0;color:#fff}
    .header-info h2{font-size:1.1rem;font-weight:700}
    .rol-badge{display:inline-block;background:rgba(99,102,241,.15);color:var(--primary);border-radius:2rem;padding:.2rem .75rem;font-size:.75rem;font-weight:600;text-transform:capitalize;margin-top:.25rem}
    .section-title{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:1rem;margin-top:1.5rem}
    .field{margin-bottom:1rem}
    .field label{display:block;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin-bottom:.4rem}
    .field input{width:100%;padding:.72rem 1rem;background:var(--surface-2);border:1.5px solid var(--border);border-radius:.6rem;font-size:.9rem;font-family:'Inter',sans-serif;color:var(--text);outline:none;transition:border-color .2s,box-shadow .2s}
    .field input::placeholder{color:#4a5068}
    .field input:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(99,102,241,.15)}
    .field input:disabled{background:#16192480;color:var(--muted);border-color:#1e2235;cursor:not-allowed;opacity:.7}
    .field .hint-lock{color:#4a5068;display:flex;align-items:center;gap:.3rem}
    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .btn-submit{width:100%;background:var(--primary);color:#fff;border:none;border-radius:.75rem;padding:.875rem;font-size:1rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;transition:background .2s;margin-top:1rem}
    .btn-submit:hover{background:var(--primary-hover)}
    .btn-submit:active{transform:scale(.98)}
    .btn-back{display:inline-flex;align-items:center;gap:.4rem;color:var(--muted);font-size:.85rem;text-decoration:none;margin-bottom:1.5rem;transition:color .2s}
    .btn-back:hover{color:var(--text)}
    @media(max-width:480px){.grid-2{grid-template-columns:1fr}}
  </style>
</head>
<body>
<div class="card">
  <a href="/<%= user.nombre_rol %>" class="btn-back">← Volver al panel</a>

  <div class="header">
    <!-- avatar e info usan usuario (BD) para mostrar datos frescos -->
    <div class="avatar"><%= usuario.nombre.charAt(0).toUpperCase() %></div>
    <div class="header-info">
      <h2><%= usuario.nombre %></h2>
      <span class="rol-badge"><%= user.nombre_rol %></span>
    </div>
  </div>

  <form action="/perfil" method="POST">
    <div class="section-title">Información personal</div>

    <div class="field">
      <label>Nombre completo</label>
      <input type="text" name="nombre" value="<%= usuario.nombre %>" required>
    </div>

    <div class="grid-2">
      <div class="field">
        <label>Correo electrónico</label>
        <input type="email" name="correo" value="<%= usuario.correo %>" required>
      </div>
      <div class="field">
        <label>Teléfono</label>
        <input type="text" name="telefono" value="<%= usuario.telefono || '' %>" placeholder="3001234567">
      </div>
    </div>

    <div class="grid-2">
      <div class="field">
        <label>Facultad</label>
        <input type="text" name="facultad" value="<%= usuario.facultad || '' %>" placeholder="Ej: Ingeniería de Sistemas">
      </div>
      <div class="field">
        <label>Rol</label>
        <!-- disabled: no se envía al servidor, el rol nunca cambia -->
        <input type="text" value="<%= user.nombre_rol %>" disabled>
        <small class="hint-lock">🔒 No modificable</small>
      </div>
    </div>

    <div class="section-title">Cambiar contraseña</div>

    <div class="field">
      <label>Nueva contraseña</label>
      <input type="password" name="contrasena_nueva" placeholder="Dejar vacío para no cambiar">
      <small style="color:var(--muted)">Solo completa este campo si deseas cambiar tu contraseña actual</small>
    </div>

    <button type="submit" class="btn-submit">💾 Guardar cambios</button>
  </form>
</div>

<% if (alert) { %>
<script>
  Swal.fire({
    title: '<%- alertTitle %>',
    text: '<%- alertMessage %>',
    icon: '<%- alertIcon %>',
    showConfirmButton: <%= showConfirmButton %>,
    <% if (timer) { %>timer: <%= timer %>,<% } %>
    background: '#1a1d27',
    color: '#f1f5f9',
    confirmButtonColor: '#6366f1'
  }).then(() => {
    window.location.href = '/<%= ruta %>'
  })
</script>
<% } %>
</body>
</html>